# REQUIRED
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# OPTIONAL (TA module fallback)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# API KEYS
COINALYZE_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
GITHUB_TOKEN=
TWITTER_BEARER_TOKEN=
X_BEARER_TOKEN=
YOUTUBE_API_KEY=
COINGECKO_API_KEY=

# BOT / ACCESS
ALLOWED_CHAT_IDS=
ADMIN_CHAT_ID=
WEBAPP_URL=https://joshuabuyan.github.io/trade-view/

# DEPLOYMENT MODE
LOW_RAM_MODE=true
LIGHT_START_MODE=true
DISABLE_CHARTS=false
MAX_NEWS_PHOTOS=3
MAX_RAM_MB=128

# TA QUEUE (recommended for low RAM)
TA_QUEUE_ENABLED=1
TA_QUEUE_MAX_PENDING=1
TA_QUEUE_BUSY_NOTICE=1

# WEBHOOK (leave disabled when using polling)
USE_WEBHOOK=false
WEBHOOK_URL=
WEBHOOK_PORT=8443
WEBHOOK_PATH=/webhook

# STORAGE / RUNTIME FILES
# Keep these out of Git and let the app create them at runtime.
APEX_WATCH_STORE_FILE=/tmp/apex_watch_store.json
GATE_MEMORY_FILE=/tmp/gate_memory.json
GATE_BLACKLIST_FILE=/tmp/gate_blacklist.json
CONDITIONS_FILE=/tmp/conditions.json
DEEP_STRUCT_FILE=/tmp/deep_struct_cache.json
DEEP_STRUCT_REFRESH_HOURS=6
MARKOV_BRAIN_PATH=/tmp/markov_brain.json
STRUCT_LOG_FILE=/tmp/mop_ict_structured.jsonl
STRUCT_LOG_MAX_BYTES=131072
POLY_PAPER_DB=/tmp/poly_paper.db
POLY_PAPER_FILE=/tmp/poly_paper.json

# TA / FETCH TUNING
FETCH_FUNNEL_MODE=1
EXCHANGE_FETCH_BATCH=1
PROBE_FETCH_BATCH=1
FETCH_FUNNEL_PAUSE_MS=35
FETCH_FUNNEL_CONNECTOR=4
USE_GH_MICRO_SHADOW=1
GH_MICRO_SHADOW_VERBOSE=0
GATE_11_THRESHOLD=2

# AIRDROPS / NEWS
AIRDROP_TOP_N=10
AIRDROP_TIMEOUT=12
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
AIRDROP_RSS_URLS=
AIRDROP_EVENT_RSS_URLS=

# OPTIONAL PHASE 2 / POLYMARKET LIVE
POLY_PRIVATE_KEY=
POLY_LIVE_ENABLED=false
